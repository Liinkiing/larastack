{
  "name": "@larastack/mobile",
  "version": "54.0.35",
  "license": "0BSD",
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "expo:doctor": "npx expo-doctor",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "gen:gql": "graphql-codegen --config codegen.ts",
    "gen:gql:watch": "graphql-codegen --config codegen.ts --watch",
    "prets:check": "pnpm run gen:gql",
    "ts:check": "tsc --pretty --skipLibCheck --noEmit",
    "test": "vitest",
    "test:ci": "vitest run",
    "test:watch": "vitest --watch",
    "lint": "oxlint --report-unused-disable-directives-severity error",
    "lint:fix": "oxlint --fix --report-unused-disable-directives-severity error",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "build:dev:ios": "npx eas-cli@latest build -p ios --profile development",
    "build:dev:android": "npx eas-cli@latest build -p android --profile development",
    "build:preview:ios": "npx eas-cli@latest build -p ios --profile preview",
    "build:preview:android": "npx eas-cli@latest build -p android --profile preview",
    "build:prod:ios": "npx eas-cli@latest build -p ios --profile production",
    "build:prod:android": "npx eas-cli@latest build -p android --profile production",
    "submit:testflight": "npx testflight",
    "build:list": "npx eas-cli@latest build:list",
    "build:view": "npx eas-cli@latest build:view",
    "draft": "npx eas-cli@latest workflow:run create-draft.yml",
    "development-builds": "npx eas-cli@latest workflow:run create-development-builds.yml",
    "deploy": "npx eas-cli@latest workflow:run deploy-to-production.yml"
  },
  "dependencies": {
    "@apollo/client": "^4.1.6",
    "@expo/metro-runtime": "~55.0.6",
    "@expo/vector-icons": "^15.0.2",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-navigation/bottom-tabs": "^7.10.1",
    "@react-navigation/elements": "^2.9.5",
    "@react-navigation/native": "^7.1.28",
    "expo": "55.0.5",
    "expo-apple-authentication": "~55.0.8",
    "expo-constants": "~55.0.7",
    "expo-dev-client": "~55.0.11",
    "expo-device": "~55.0.9",
    "expo-font": "~55.0.4",
    "expo-haptics": "~55.0.8",
    "expo-image": "~55.0.6",
    "expo-linking": "~55.0.7",
    "expo-router": "55.0.4",
    "expo-secure-store": "~55.0.8",
    "expo-splash-screen": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.5",
    "expo-system-ui": "~55.0.9",
    "expo-updates": "~55.0.12",
    "expo-web-browser": "~55.0.9",
    "graphql": "^16.13.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "~4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.2",
    "rxjs": "^7.3.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "uniwind": "^1.3.2"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^6.1.3",
    "@graphql-codegen/client-preset": "^5.2.4",
    "@graphql-codegen/fragment-matcher": "^6.0.0",
    "@graphql-codegen/typescript-apollo-client-helpers": "^3.0.1",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/react": "~19.2.14",
    "eslint-plugin-expo": "^1.0.0",
    "lightningcss": "1.30.1",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.18"
  }
}
