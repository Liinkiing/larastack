{
  "name": "@larastack/mobile",
  "version": "0.0.0",
  "license": "0BSD",
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "expo:doctor": "npx expo-doctor",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "gen:gql": "graphql-codegen --config codegen.ts",
    "gen:gql:watch": "graphql-codegen --config codegen.ts --watch",
    "prets:check": "pnpm run gen:gql",
    "ts:check": "tsc --pretty --skipLibCheck --noEmit",
    "test": "vitest",
    "test:ci": "vitest run",
    "test:watch": "vitest --watch",
    "lint": "oxlint --report-unused-disable-directives-severity error",
    "lint:fix": "oxlint --fix --report-unused-disable-directives-severity error",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "build:dev:ios": "npx eas-cli@latest build -p ios --profile development",
    "build:dev:android": "npx eas-cli@latest build -p android --profile development",
    "build:preview:ios": "npx eas-cli@latest build -p ios --profile preview",
    "build:preview:android": "npx eas-cli@latest build -p android --profile preview",
    "build:prod:ios": "npx eas-cli@latest build -p ios --profile production",
    "build:prod:android": "npx eas-cli@latest build -p android --profile production",
    "submit:testflight": "npx testflight",
    "build:list": "npx eas-cli@latest build:list",
    "build:view": "npx eas-cli@latest build:view",
    "draft": "npx eas-cli@latest workflow:run create-draft.yml",
    "development-builds": "npx eas-cli@latest workflow:run create-development-builds.yml",
    "deploy": "npx eas-cli@latest workflow:run deploy-to-production.yml"
  },
  "dependencies": {
    "@apollo/client": "^4.1.8",
    "@expo/dom-webview": "56.0.4",
    "@expo/metro-runtime": "~56.0.13",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-native-vector-icons/material-icons": "^13.1.1",
    "expo": "56.0.6",
    "expo-apple-authentication": "~56.0.4",
    "expo-constants": "~56.0.16",
    "expo-dev-client": "~56.0.16",
    "expo-device": "~56.0.4",
    "expo-font": "~56.0.5",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.9",
    "expo-linking": "~56.0.12",
    "expo-router": "56.2.7",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.5",
    "expo-system-ui": "~56.0.5",
    "expo-updates": "~56.0.17",
    "expo-web-browser": "~56.0.5",
    "graphql": "^16.13.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.2",
    "react-native-reanimated": "~4.4.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.9.1",
    "rxjs": "^7.3.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "uniwind": "^1.7.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^6.3.1",
    "@graphql-codegen/client-preset": "^5.3.0",
    "@graphql-codegen/fragment-matcher": "^6.0.1",
    "@graphql-codegen/typescript-apollo-client-helpers": "^4.0.1",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/react": "~19.2.14",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint-plugin-expo": "^1.0.0",
    "lightningcss": "1.30.1",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.2",
    "vitest": "^4.1.5"
  },
  "expo": {
    "install": {
      "exclude": [
        "react-native-reanimated",
        "react-native-worklets"
      ]
    }
  }
}
