{
  "name": "@larastack/mobile",
  "version": "0.0.0",
  "license": "0BSD",
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "expo:doctor": "npx expo-doctor",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "gen:gql": "graphql-codegen --config codegen.ts",
    "gen:gql:watch": "graphql-codegen --config codegen.ts --watch",
    "prets:check": "pnpm run gen:gql",
    "ts:check": "tsc --pretty --skipLibCheck --noEmit",
    "pretest": "pnpm run gen:gql",
    "test": "vitest",
    "pretest:ci": "pnpm run gen:gql",
    "test:ci": "vitest run",
    "pretest:watch": "pnpm run gen:gql",
    "test:watch": "vitest --watch",
    "lint": "oxlint --report-unused-disable-directives-severity error",
    "lint:fix": "oxlint --fix --report-unused-disable-directives-severity error",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "build:dev:ios": "npx eas-cli@latest build -p ios --profile development",
    "build:dev:android": "npx eas-cli@latest build -p android --profile development",
    "build:preview:ios": "npx eas-cli@latest build -p ios --profile preview",
    "build:preview:android": "npx eas-cli@latest build -p android --profile preview",
    "build:prod:ios": "npx eas-cli@latest build -p ios --profile production",
    "build:prod:android": "npx eas-cli@latest build -p android --profile production",
    "submit:testflight": "npx testflight",
    "build:list": "npx eas-cli@latest build:list",
    "build:view": "npx eas-cli@latest build:view",
    "draft": "npx eas-cli@latest workflow:run create-draft.yml",
    "development-builds": "npx eas-cli@latest workflow:run create-development-builds.yml",
    "deploy": "npx eas-cli@latest workflow:run deploy-to-production.yml"
  },
  "dependencies": {
    "@apollo/client": "^4.2.6",
    "@expo/dom-webview": "57.0.0",
    "@expo/metro-runtime": "~57.0.3",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-native-vector-icons/material-icons": "^13.1.2",
    "expo": "57.0.4",
    "expo-apple-authentication": "~57.0.0",
    "expo-build-properties": "~57.0.3",
    "expo-constants": "~57.0.3",
    "expo-dev-client": "~57.0.5",
    "expo-device": "~57.0.0",
    "expo-font": "~57.0.0",
    "expo-haptics": "~57.0.0",
    "expo-image": "~57.0.0",
    "expo-linking": "~57.0.2",
    "expo-router": "57.0.4",
    "expo-secure-store": "~57.0.0",
    "expo-splash-screen": "~57.0.2",
    "expo-status-bar": "~57.0.0",
    "expo-symbols": "~57.0.0",
    "expo-system-ui": "~57.0.0",
    "expo-updates": "~57.0.6",
    "expo-web-browser": "~57.0.0",
    "graphql": "^16.14.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "~4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.10.0",
    "rxjs": "^7.8.2",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "uniwind": "^1.10.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^7.2.0",
    "@graphql-codegen/client-preset": "^6.1.0",
    "@graphql-codegen/fragment-matcher": "^7.1.0",
    "@graphql-codegen/typescript-apollo-client-helpers": "^4.0.1",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@react-native/metro-config": "0.86.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/react": "~19.2.17",
    "@typescript/native": "catalog:",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint-plugin-expo": "^1.1.0",
    "lightningcss": "1.30.1",
    "tailwindcss": "^4.3.2",
    "typescript": "catalog:",
    "vitest": "^4.1.10"
  }
}
