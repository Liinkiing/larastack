{
  "name": "@larastack/frontend",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "predev": "graphql-codegen --config codegen.ts",
    "dev": "next dev --turbopack",
    "prebuild": "pnpm run gen:gql",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "oxlint --report-unused-disable-directives-severity error",
    "lint:fix": "oxlint --fix --report-unused-disable-directives-severity error",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "gen:gql": "graphql-codegen --config codegen.ts",
    "gen:gql:watch": "graphql-codegen --config codegen.ts --watch",
    "prets:check": "pnpm run gen:gql",
    "ts:check": "tsc --pretty --skipLibCheck --noEmit",
    "test": "vitest",
    "test:ci": "vitest run",
    "test:watch": "vitest --watch",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@apollo/client": "^4.1.6",
    "@base-ui/react": "^1.6.0",
    "@hookform/resolvers": "^5.2.2",
    "apollo-upload-client": "^19.0.0",
    "axios": "^1.14.0",
    "graphql": "^16.13.2",
    "js-cookie": "^3.0.5",
    "motion": "^12.38.0",
    "next": "16.2.1",
    "next-transition-router": "^0.2.11",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.0",
    "rxjs": "^7.8.2",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.1",
    "@graphql-codegen/add": "^6.0.0",
    "@graphql-codegen/cli": "^6.2.1",
    "@graphql-codegen/client-preset": "^5.2.4",
    "@graphql-codegen/fragment-matcher": "^6.0.0",
    "@graphql-codegen/introspection": "5.0.1",
    "@graphql-codegen/typescript-apollo-client-helpers": "^4.0.0",
    "@graphql-eslint/eslint-plugin": "^4.4.0",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/nextjs-vite": "10.3.3",
    "@storybook/react": "^10.3.3",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint-plugin-storybook": "10.3.3",
    "jsdom": "^29.0.1",
    "storybook": "^10.3.3",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
