{
  "name": "@larastack/frontend",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "predev": "graphql-codegen --config codegen.ts && pnpm run gen:panda",
    "dev": "next dev --turbopack",
    "prebuild": "panda codegen && pnpm run gen:gql",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "oxlint --report-unused-disable-directives-severity error",
    "lint:fix": "oxlint --fix --report-unused-disable-directives-severity error",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "prepare": "panda codegen",
    "gen:panda:watch": "panda codegen --watch",
    "gen:panda": "panda codegen",
    "gen:gql": "graphql-codegen --config codegen.ts",
    "gen:gql:watch": "graphql-codegen --config codegen.ts --watch",
    "prets:check": "panda codegen && pnpm run gen:gql",
    "ts:check": "tsc --pretty --skipLibCheck --noEmit",
    "test": "vitest",
    "test:ci": "vitest run",
    "test:watch": "vitest --watch",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@apollo/client": "^4.2.6",
    "@ark-ui/react": "^5.37.2",
    "@hookform/resolvers": "^5.4.0",
    "apollo-upload-client": "^19.0.0",
    "axios": "^1.18.1",
    "deepmerge": "^4.3.1",
    "graphql": "^16.14.2",
    "js-cookie": "^3.0.8",
    "motion": "^12.42.2",
    "next": "16.2.10",
    "next-transition-router": "^0.2.11",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "rxjs": "^7.8.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@graphql-codegen/add": "^7.1.0",
    "@graphql-codegen/cli": "^7.2.0",
    "@graphql-codegen/client-preset": "^6.1.0",
    "@graphql-codegen/fragment-matcher": "^7.1.0",
    "@graphql-codegen/introspection": "6.1.0",
    "@graphql-codegen/typescript-apollo-client-helpers": "^4.0.1",
    "@graphql-eslint/eslint-plugin": "^4.4.0",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@pandacss/dev": "^1.11.4",
    "@pandacss/shared": "^1.11.4",
    "@pandacss/studio": "^1.11.4",
    "@storybook/addon-docs": "^10.5.0",
    "@storybook/nextjs-vite": "10.5.0",
    "@storybook/react": "^10.5.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/apollo-upload-client": "^19.0.0",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript/native": "catalog:",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint-plugin-storybook": "10.5.0",
    "jsdom": "^29.1.1",
    "storybook": "^10.5.0",
    "typescript": "catalog:",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
