{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": false,
  "arrowParens": "avoid",
  "ignorePatterns": [
    ".agents/**/*",
    ".github/**/*",
    ".husky/**/*",
    "backend/vendor/**/*",
    "backend/public/vendor/**/*",
    "uniwind-types.d.ts"
  ],
  "printWidth": 120,
  "singleQuote": true,
  "sortImports": {
    "newlinesBetween": true
  },
  "sortTailwindcss": {
    "stylesheet": "./mobile/src/global.css",
    "functions": ["clsx", "cn", "cva", "tv"],
    "preserveWhitespace": true
  }
}
