{
  "name": "@larastack/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "lint": "./vendor/bin/sail pint",
    "test": "./vendor/bin/sail pest",
    "typecheck": "./vendor/bin/sail bin phpstan",
    "db:reset": "./vendor/bin/sail artisan migrate:fresh --seed",
    "gql:dump": "./vendor/bin/sail artisan lighthouse:print-schema --write && ./scripts/sync-gql-schema.sh",
    "gql:ide-helper": "./vendor/bin/sail artisan lighthouse:ide-helper --omit-built-in"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "axios": "^1.13.6",
    "concurrently": "^9.2.1",
    "laravel-vite-plugin": "^2.1.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.13",
    "vite": "^7.3.1"
  }
}
